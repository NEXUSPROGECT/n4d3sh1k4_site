# Используем легковесный официальный образ Nginx в качестве веб-сервера
FROM nginx:alpine

# Копируем все файлы нашего статического сайта в стандартную директорию Nginx
COPY . /usr/share/nginx/html

# Указываем, что контейнер слушает 80 порт
EXPOSE 80

# Nginx запускается автоматически базовым образом, так что CMD не обязателен, 
# но для явности можно оставить поведение по умолчанию
CMD ["nginx", "-g", "daemon off;"]
